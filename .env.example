# Copy this file to ".env" and fill in your values.
# This app talks to an OpenAI-compatible AWS Bedrock gateway.
# The SAME endpoint/model powers both LLMs (the generator + the chatbot).

AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=eu-north-1
AWS_DEFAULT_REGION=eu-north-1

BEDROCK_PROJECT=your-project-id
BEDROCK_BASE_URL=https://bedrock-mantle.eu-north-1.api.aws/v1
BEDROCK_MODEL=openai.gpt-oss-120b

# Bearer token used as the OpenAI-compatible API key (if your gateway issues one).
# Falls back to AWS_SECRET_ACCESS_KEY when unset.
# BEDROCK_API_KEY=

# Optional overrides:
# PORT=3000
# GENERATE_EVERY_MS=25000
# MAX_CONTEXT_ITEMS=40
# CONTEXT_ITEMS_FOR_CHAT=15
